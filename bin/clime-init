#!/usr/bin/env bash
# clime-init — Add a polyglot shebang header to an Emacs Lisp file,
# making it directly executable as a CLI app powered by clime.
#
# Usage:
#   clime-init FILE.el [EXTRA_LOAD_PATH ...]
#
# Resolves the local clime installation directory and writes a two-line
# shebang header that adds clime (and any extra paths) to the Emacs
# load path.  Also makes the file executable.
#
# If the file already has a shebang (#!), the script aborts.

set -euo pipefail

usage() {
    cat <<EOF
Usage: clime-init FILE.el [EXTRA_LOAD_PATH ...]

Add a polyglot shebang header to FILE.el so it can be run directly:

  clime-init myapp.el
  ./myapp.el --help

Extra load paths are added as additional -L flags:

  clime-init myapp.el ./lib ./vendor

EOF
    exit "${1:-0}"
}

# --- Resolve clime root ---
# Follow symlinks to find the real location of this script,
# then derive clime's root directory.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
CLIME_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Sanity check: clime.el should exist in the resolved directory
if [ ! -f "$CLIME_DIR/clime.el" ]; then
    echo "error: cannot find clime.el in $CLIME_DIR" >&2
    exit 1
fi

# --- Parse args ---
if [ $# -lt 1 ] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    usage 0
fi

TARGET="$1"
shift

if [ ! -f "$TARGET" ]; then
    echo "error: file not found: $TARGET" >&2
    exit 1
fi

# Check for existing shebang
if head -1 "$TARGET" | grep -q '^#!'; then
    echo "error: $TARGET already has a shebang line" >&2
    echo "hint: remove the first two lines if you want to regenerate" >&2
    exit 1
fi

# --- Build -L flags ---
LOAD_FLAGS="-L \"$CLIME_DIR\""
for extra in "$@"; do
    abs="$(cd "$extra" && pwd)"
    LOAD_FLAGS="$LOAD_FLAGS -L \"$abs\""
done

# --- Build header ---
HEADER="#!/bin/sh
\":\" ; exec emacs --batch -Q $LOAD_FLAGS -l \"\$0\" -- \"\$@\" # -*-emacs-lisp-*-"

# --- Prepend header ---
TMPFILE="$(mktemp)"
trap 'rm -f "$TMPFILE"' EXIT

{
    echo "$HEADER"
    cat "$TARGET"
} > "$TMPFILE"

mv "$TMPFILE" "$TARGET"
trap - EXIT  # cancel cleanup since mv succeeded
chmod +x "$TARGET"

echo "done: $TARGET is now executable"
echo "  $HEADER" | head -2
